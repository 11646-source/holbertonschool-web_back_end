import psycopg2
from psycopg2 import sql

conn = psycopg2.connect(dbname="postgres", user="your_user", password="your_password")
conn.autocommit = True
cur = conn.cursor()

cur.execute("SELECT 1 FROM pg_database WHERE datname='my_db'")
if not cur.fetchone():
    cur.execute(sql.SQL("CREATE DATABASE {}").format(sql.Identifier("my_db")))

print("Database 'my_db' is ready to use.")

